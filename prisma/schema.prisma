generator client {
  provider   = "prisma-client"
  output     = "../lib/generated/prisma"
  engineType = "binary"
}

datasource db {
  provider = "sqlite"
}

model User {
  id              String                 @id @default(uuid())
  email           String                 @unique
  name            String?
  role            Role                   @default(END_USER)
  customRoleId    String?
  customRole      CustomRole?            @relation(fields: [customRoleId], references: [id])
  department      String?
  createdAt       DateTime               @default(now())
  updatedAt       DateTime               @updatedAt
  externalId      String?                @unique
  avatarUrl       String?
  emailVerified   DateTime?
  passwordHash    String?
  accounts        Account[]
  assets          Asset[]
  comments        Comment[]
  articles        KnowledgeBaseArticle[]
  sessions        Session[]
  assignedTickets Ticket[]               @relation("AssignedTickets")
  tickets         Ticket[]
  userPermissions UserPermission[]
  auditLogs       AuditLog[]

  @@map("users")
}

model Ticket {
  id                 String       @id @default(uuid())
  title              String
  description        String
  status             TicketStatus @default(NEW)
  priority           Priority     @default(MEDIUM)
  category           String?
  tags               String
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt
  closedAt           DateTime?
  userId             String
  assignedToId       String?
  assetId            String?
  slaId              String?
  firstResponseAt    DateTime?
  resolvedAt         DateTime?
  source             TicketSource @default(PORTAL)
  impact             ImpactLevel  @default(LOW)
  urgency            UrgencyLevel @default(LOW)
  calculatedPriority Priority?
  comments           Comment[]
  sla                SLA?         @relation(fields: [slaId], references: [id])
  asset              Asset?       @relation(fields: [assetId], references: [id])
  assignedTo         User?        @relation("AssignedTickets", fields: [assignedToId], references: [id])
  user               User         @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([assignedToId])
  @@index([assetId])
  @@index([slaId])
  @@map("tickets")
}

model Comment {
  id         String   @id @default(uuid())
  content    String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  ticketId   String
  userId     String
  isInternal Boolean  @default(false)
  user       User     @relation(fields: [userId], references: [id])
  ticket     Ticket   @relation(fields: [ticketId], references: [id])

  @@index([ticketId])
  @@index([userId])
  @@map("comments")
}

model Asset {
  id           String      @id @default(uuid())
  name         String
  type         AssetType
  serialNumber String?     @unique
  location     String?
  status       AssetStatus @default(ACTIVE)
  purchaseDate DateTime?
  warrantyEnd  DateTime?
  licenseKey   String?
  notes        String?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  userId       String?
  user         User?       @relation(fields: [userId], references: [id])
  tickets      Ticket[]

  @@index([userId])
  @@map("assets")
}

model SLA {
  id               String   @id @default(uuid())
  name             String
  description      String?
  priority         Priority
  responseTime     Int
  resolutionTime   Int
  escalationLevels Int      @default(3)
  isActive         Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  tickets          Ticket[]

  @@map("slas")
}

model KnowledgeBaseArticle {
  id              String   @id @default(uuid())
  title           String
  content         String
  category        String
  tags            String
  isPublished     Boolean  @default(false)
  viewCount       Int      @default(0)
  helpfulCount    Int      @default(0)
  notHelpfulCount Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  authorId        String
  author          User     @relation(fields: [authorId], references: [id])

  @@index([authorId])
  @@map("knowledge_base_articles")
}

model AutomationRule {
  id          String   @id @default(uuid())
  name        String
  description String?
  trigger     String
  condition   String?
  action      String
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("automation_rules")
}

model Account {
  id                String  @id @default(uuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(uuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

enum Role {
  ADMIN
  AGENT
  END_USER
  CUSTOM
}

model PermissionCategory {
  id          String       @id @default(uuid())
  name        String       @unique  // "tickets", "users", "assets", etc.
  description String?
  order       Int          @default(0)
  permissions Permission[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  
  @@map("permission_categories")
}

model Permission {
  id          String   @id @default(uuid())
  name        String   @unique
  description String?
  category    String   // e.g., "tickets", "users", "settings", "reports", "assets"
  action      String   // e.g., "create", "read", "update", "delete", "manage"
  categoryId  String?
  permissionCategory PermissionCategory? @relation(fields: [categoryId], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  rolePermissions RolePermission[]
  userPermissions UserPermission[]

  @@map("permissions")
}

model RolePermission {
  id           String     @id @default(uuid())
  role         Role?      // For standard roles (ADMIN, AGENT, END_USER)
  customRoleId String?    // For custom roles
  customRole   CustomRole? @relation(fields: [customRoleId], references: [id])
  permissionId String
  permission   Permission @relation(fields: [permissionId], references: [id])
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@unique([role, permissionId])
  @@unique([customRoleId, permissionId])
  @@map("role_permissions")
}

model UserPermission {
  id           String     @id @default(uuid())
  userId       String
  user         User       @relation(fields: [userId], references: [id])
  permissionId String
  permission   Permission @relation(fields: [permissionId], references: [id])
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@unique([userId, permissionId])
  @@map("user_permissions")
}

model CustomRole {
  id          String   @id @default(uuid())
  name        String   @unique
  description String?
  isActive    Boolean  @default(true)
  permissions RolePermission[]
  users       User[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("custom_roles")
}

model RoleHierarchy {
  id         String   @id @default(uuid())
  parentRole Role     // Übergeordnete Rolle
  childRole  Role     // Untergeordnete Rolle
  createdAt  DateTime @default(now())
  
  @@unique([parentRole, childRole])
  @@map("role_hierarchies")
}

enum TicketStatus {
  NEW
  ASSIGNED
  IN_PROGRESS
  RESOLVED
  CLOSED
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum TicketSource {
  PORTAL
  EMAIL
  PHONE
  CHAT
}

enum ImpactLevel {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum UrgencyLevel {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum AssetType {
  LAPTOP
  DESKTOP
  MONITOR
  PHONE
  PRINTER
  SOFTWARE
  SERVER
  NETWORK
  OTHER
}

enum AssetStatus {
  ACTIVE
  INACTIVE
  MAINTENANCE
  RETIRED
  LOST
}

model AuditLog {
  id          String   @id @default(uuid())
  action      String   // e.g., "PERMISSION_CHANGE", "ROLE_CREATE", "USER_ASSIGN"
  entityType  String   // e.g., "Role", "Permission", "User"
  entityId    String?
  userId      String?
  user        User?    @relation(fields: [userId], references: [id])
  details     String?  // JSON details of the change
  ipAddress   String?
  userAgent   String?
  createdAt   DateTime @default(now())
  
  @@index([action])
  @@index([entityType, entityId])
  @@index([userId])
  @@index([createdAt])
  @@map("audit_logs")
}

model IntegrationConfig {
  id        String   @id @default(uuid())
  provider  String   @unique
  name      String
  config    String   // JSON configuration
  enabled   Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("integration_configs")
}
