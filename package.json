{
  "name": "itsm-app",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:turbo": "next dev",
    "dev:fix-turbo": "set TURBO_CACHE_DIR=.turbo-cache&& next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "seed": "tsx prisma/seed.ts",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate deploy",
    "prisma:studio": "prisma studio",
    "prisma:reset": "prisma migrate reset --force",
    "migrate:postgresql": "node scripts/migrate-dev.js",
    "test:security": "node scripts/run-security-tests.js",
    "test:security:auth": "npx jest tests/security/auth.test.ts --config=tests/security/jest.config.js",
    "test:security:validation": "npx jest tests/security/validation.test.ts --config=tests/security/jest.config.js",
    "test:security:api": "npx jest tests/security/api.test.ts --config=tests/security/jest.config.js"
  },
  "dependencies": {
